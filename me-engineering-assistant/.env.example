# ── Model provider ────────────────────────────────────────────────────────────
# "openai"     → uses OpenAI API (default for local development)
# "databricks" → uses Databricks-served models (for production)
MODEL_PROVIDER=openai

# ── OpenAI (required when MODEL_PROVIDER=openai) ──────────────────────────────
# ONE key covers BOTH the LLM and the embedding model.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# LLM used by the ReAct agent
LLM_MODEL_NAME=gpt-4o-mini

# Embedding model used to build the FAISS indices
# text-embedding-3-small is sufficient for this 11-chunk corpus and is cheaper
# than text-embedding-3-large with no measurable accuracy difference at this scale.
EMBEDDING_MODEL_NAME=text-embedding-3-small

# ── Databricks (required only when MODEL_PROVIDER=databricks) ─────────────────
# DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
# DATABRICKS_TOKEN=dapi...
# LLM_MODEL_NAME=databricks-meta-llama-3-1-70b-instruct
# EMBEDDING_MODEL_NAME=databricks-gte-large-en
